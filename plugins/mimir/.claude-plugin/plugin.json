{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "mimir",
  "displayName": "Perseus Vault — Encrypted Persistent Memory",
  "description": "Local-first, encrypted persistent memory for AI agents: 46 MCP tools over SQLite + FTS5 hybrid search, single Rust binary, fully offline. Exposes the Perseus Vault MCP server to Claude Code.",
  "version": "1.0.0",
  "author": {
    "name": "Perseus Computing LLC",
    "url": "https://github.com/Perseus-Computing-LLC"
  },
  "homepage": "https://github.com/Perseus-Computing-LLC/perseus-vault",
  "repository": "https://github.com/Perseus-Computing-LLC/perseus-vault",
  "license": "MIT",
  "keywords": ["memory", "persistent-memory", "encrypted", "offline", "mcp"],
  "mcpServers": {
    "mimir": {
      "command": "mimir",
      "args": ["serve", "--db", "${CLAUDE_PLUGIN_DATA}/mimir.db"]
    }
  }
}
