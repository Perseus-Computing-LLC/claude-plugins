{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "perseus",
  "displayName": "Perseus — Live Context Engine",
  "description": "Pre-resolves git, services, tests, and memory into a ready context briefing at session start (compile-before-context). Exposes the Perseus MCP server to Claude Code.",
  "version": "1.0.0",
  "author": {
    "name": "Perseus Computing LLC",
    "url": "https://github.com/Perseus-Computing-LLC"
  },
  "homepage": "https://github.com/Perseus-Computing-LLC/perseus",
  "repository": "https://github.com/Perseus-Computing-LLC/perseus",
  "license": "MIT",
  "keywords": ["context", "context-engineering", "mcp", "agents", "git"],
  "mcpServers": {
    "perseus": {
      "command": "perseus",
      "args": ["mcp", "serve", "--workspace", "${CLAUDE_PROJECT_DIR}"]
    }
  }
}
